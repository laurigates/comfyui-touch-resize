{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": { "noForEach": "warn" },
      "style": { "noNonNullAssertion": "warn", "useConst": "error" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "**/tests/js/**/*.js",
      "vitest.config.js",
      "package.json",
      "knip.json",
      "tsconfig.json",
      "!**/node_modules",
      "!**/web/dist",
      "!**/dist",
      "!**/coverage"
    ]
  }
}
